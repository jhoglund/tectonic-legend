{
  "extends": "@hoglund/config/tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode (Tectonic-specific extras on top of the base) */
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "noEmit": true,

    /* The base sets baseUrl ".", but extends resolves it relative to the base
       file in node_modules; re-declare it locally so @/* maps into this repo. */
    "baseUrl": "."
  },
  "include": ["src"]
}
