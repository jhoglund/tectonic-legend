{
  "name": "tectonic-legend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 7576 --strictPort",
    "build": "npm run typecheck && vite build",
    "build:ios": "npm run typecheck && vite build --mode capacitor",
    "sync:ios": "npm run build:ios && cap sync ios",
    "lint": "biome lint .",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.105.4",
    "react": "~19.2.0",
    "react-dom": "~19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.16",
    "@hoglund/config": "github:jhoglund/config#v0.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "~4.2.0",
    "typescript": "~5.9.0",
    "vite": "~8.0.0",
    "vitest": "^4.1.6"
  }
}
