# Mimir analytics — local dev. The SDK script and the ingest endpoint
# are served same-origin with tectonic.test via the Vite proxy (see
# vite.config.ts), which forwards them to https://mimir.test. Same-origin
# keeps the SDK first-party — past tracker blocklists, Safari ITP, CSP.
#
# The ingest token is per-developer and lives in .env.local (gitignored).
VITE_MIMIR_SCRIPT_URL=/_m/script.js
VITE_MIMIR_ENDPOINT=/_m/api/ingest
