# Mimir analytics configuration.
#
# Local dev: the script URL + endpoint are already set in the committed
# .env.development; you only need the ingest token below in a .env.local
# (gitignored). Production: set all four as repository variables/secrets
# consumed by .github/workflows/deploy.yml. When the token, script URL,
# or endpoint is missing, the app builds and runs with no analytics.

# Ingest token for the `tectonic` project in your Mimir instance.
VITE_MIMIR_TOKEN=

# Where the Mimir SDK script is loaded from.
#   dev  — /_m/script.js  (Vite proxies it to https://mimir.test/mimir.js)
#   prod — https://<your-public-mimir-host>/mimir.js
VITE_MIMIR_SCRIPT_URL=

# Where Mimir events are POSTed.
#   dev  — /_m/api/ingest
#   prod — https://<your-public-mimir-host>/api/ingest
VITE_MIMIR_ENDPOINT=

# App version tagged on every event. The deploy sets this to the commit SHA.
VITE_MIMIR_APP_VERSION=
